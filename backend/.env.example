# Copy to .env and adjust. Defaults target the docker compose dev stack.

ENVIRONMENT=dev
DEBUG=true
SECRET_KEY=dev-insecure-change-me

# The swappable generator backend. Keep `mock` on the Mac.
# Set to `cuda` only on the NVIDIA box (Phase 9).
GENERATOR_BACKEND=mock

# Database
DATABASE_URL=postgresql+psycopg2://aurora:aurora@db:5432/aurora

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Set true to run jobs inline without Redis/a worker (standalone Mac dev).
# The docker compose stack keeps this false and runs a real worker.
CELERY_TASK_ALWAYS_EAGER=false

# MinIO / S3
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=aurora
S3_SECRET_KEY=aurora-secret
S3_BUCKET=aurora-media
S3_SECURE=false

# CORS (frontend origin)
CORS_ORIGINS=["http://localhost:3000"]

# ── Audio ────────────────────────────────────────────────────────────────────
# Top-level switch: "real" uses TTS_ENGINE + faster-whisper; "mock" skips all.
AUDIO_BACKEND=real

# TTS engine (controls voiceover quality):
#   auto    → macOS `say` if on Darwin, else `espeak-ng` (zero dependencies)
#   say     → force macOS `say`
#   espeak  → force Linux `espeak-ng`
#   kokoro  → Kokoro 82M torch — BEST QUALITY; one-time ~600MB-1GB install:
#               pip install -r requirements/tts-kokoro.txt
#             Weights (~327MB) auto-download from HuggingFace on first use.
#             Set HF_HOME to control the cache directory.
#   mock    → always return fixture audio (no engine needed, great for dev)
TTS_ENGINE=auto

# Kokoro settings (only used when TTS_ENGINE=kokoro)
#   lang:  "a" = American English  "b" = British  "e" = Spanish  "f" = French
#   voice: af_heart (default) | af_bella | am_michael | bm_george | bf_emma …
#          Full list: https://huggingface.co/hexgrad/Kokoro-82M
KOKORO_LANG=a
KOKORO_DEFAULT_VOICE=af_heart

# Whisper model size for auto-subtitles: tiny | base | small | medium | large
# "base" is a good balance of speed and accuracy on CPU.
WHISPER_MODEL=base
